      "sourceType": "com.dbdocs.autoconfigure.DbvcsProperties$Validation",
      "sourceMethod": "getField()"
    },
    {
      "name": "dbdocs.scanning",
      "type": "com.dbdocs.autoconfigure.DbvcsProperties$Scanning",
      "sourceType": "com.dbdocs.autoconfigure.DbvcsProperties",
      "sourceMethod": "getScanning()"
    },
    {
      "name": "dbdocs.ui",
      "type": "com.dbdocs.autoconfigure.DbvcsProperties$Ui",
      "sourceType": "com.dbdocs.autoconfigure.DbvcsProperties",
      "sourceMethod": "getUi()"
    },
    {
      "name": "dbdocs.versioning",
      "type": "com.dbdocs.autoconfigure.DbvcsProperties$Versioning",
      "sourceType": "com.dbdocs.autoconfigure.DbvcsProperties",
