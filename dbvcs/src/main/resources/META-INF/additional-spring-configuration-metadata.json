{
  "groups": [
    {
      "name": "dbvcs",
      "type": "com.dbvcs.autoconfigure.DbvcsProperties",
      "sourceType": "com.dbvcs.autoconfigure.DbvcsProperties"
    },
    {
      "name": "dbvcs.allowed-values",
      "type": "com.dbvcs.autoconfigure.DbvcsProperties$AllowedValues",
      "sourceType": "com.dbvcs.autoconfigure.DbvcsProperties",
      "sourceMethod": "getAllowedValues()"
    },
    {
      "name": "dbvcs.validation",
      "type": "com.dbvcs.autoconfigure.DbvcsProperties$ValidationRules",
      "sourceType": "com.dbvcs.autoconfigure.DbvcsProperties",
      "sourceMethod": "getValidation()"
    },
    {
      "name": "dbvcs.validation.rules",
      "type": "com.dbvcs.autoconfigure.DbvcsProperties$ValidationRules$PackageRule",
      "sourceType": "com.dbvcs.autoconfigure.DbvcsProperties$ValidationRules"
    }
  ],
  "properties": [
    {
      "name": "dbvcs.enabled",
      "type": "java.lang.Boolean",
      "description": "Whether the dbvcs schema version control is active.",
      "defaultValue": true
    },
    {
      "name": "dbvcs.output-dir",
      "type": "java.lang.String",
      "description": "Directory (relative to working directory) where versioned JSON schema snapshots are written.",
      "defaultValue": "dbvcs-schemas"
    },
    {
      "name": "dbvcs.base-packages",
      "type": "java.lang.String",
      "description": "Comma-separated list of base packages to scan for @Entity classes. Leave empty to scan the full classpath (slower).",
      "defaultValue": ""
    },
    {
      "name": "dbvcs.ui-path",
      "type": "java.lang.String",
      "description": "URL path where the schema browser UI is served.",
      "defaultValue": "/dbvcs"
    },
    {
      "name": "dbvcs.allowed-values.modules",
      "type": "java.util.List<java.lang.String>",
      "description": "Allowed values for @BusinessModule(name). Comma-separated list of module names.",
      "defaultValue": ["ORDER","CUSTOMER","PRODUCT","INVENTORY","PAYMENT","FINANCE","SHIPPING","NOTIFICATION","AUTH","REPORTING","ADMIN","OTHER"]
    },
    {
      "name": "dbvcs.allowed-values.domains",
      "type": "java.util.List<java.lang.String>",
      "description": "Allowed values for @Domain(name). Comma-separated list of domain names.",
      "defaultValue": ["CUSTOMER","FINANCE","PAYMENTS","ORDERS","INVENTORY","LOGISTICS","COMPLIANCE","SECURITY","ANALYTICS","OTHER"]
    },
    {
      "name": "dbvcs.allowed-values.criticality-levels",
      "type": "java.util.List<java.lang.String>",
      "description": "Allowed values for @Criticality(level).",
      "defaultValue": ["LOW","MEDIUM","HIGH","CRITICAL"]
    },
    {
      "name": "dbvcs.allowed-values.table-types",
      "type": "java.util.List<java.lang.String>",
      "description": "Allowed values for @TableType(type).",
      "defaultValue": ["MASTER","TRANSACTIONAL","LOOKUP","CONFIGURATION","STAGING","AUDIT","HISTORY","TEMPORARY"]
    },
    {
      "name": "dbvcs.allowed-values.source-systems",
      "type": "java.util.List<java.lang.String>",
      "description": "Allowed values for @SourceSystem(name).",
      "defaultValue": ["CRM","ERP","SAP","SALESFORCE","INTERNAL","MANUAL","API","ETL","LEGACY","OTHER"]
    },
    {
      "name": "dbvcs.allowed-values.data-classification-levels",
      "type": "java.util.List<java.lang.String>",
      "description": "Allowed values for @DataClassification(level).",
      "defaultValue": ["PUBLIC","INTERNAL","CONFIDENTIAL","RESTRICTED"]
    },
    {
      "name": "dbvcs.allowed-values.access-levels",
      "type": "java.util.List<java.lang.String>",
      "description": "Allowed values for @AccessLevel(level).",
      "defaultValue": ["PUBLIC","INTERNAL_ONLY","RESTRICTED","ADMIN_ONLY"]
    },
    {
      "name": "dbvcs.allowed-values.pii-types",
      "type": "java.util.List<java.lang.String>",
      "description": "Allowed values for @PiiCategory(type).",
      "defaultValue": ["NAME","EMAIL","PHONE","ADDRESS","DATE_OF_BIRTH","NATIONAL_ID","PASSPORT","SSN","IP_ADDRESS","DEVICE_ID","BIOMETRIC","FINANCIAL","HEALTH","OTHER"]
    },
    {
      "name": "dbvcs.allowed-values.lawful-basis-types",
      "type": "java.util.List<java.lang.String>",
      "description": "Allowed values for @LawfulBasis(type).",
      "defaultValue": ["CONSENT","CONTRACT","LEGAL_OBLIGATION","VITAL_INTERESTS","PUBLIC_TASK","LEGITIMATE_INTERESTS"]
    },
    {
      "name": "dbvcs.allowed-values.encryption-types",
      "type": "java.util.List<java.lang.String>",
      "description": "Allowed values for @Encrypted(algorithm).",
      "defaultValue": ["AES128","AES256","RSA","BCRYPT","ARGON2","OTHER"]
    },
    {
      "name": "dbvcs.allowed-values.masking-strategies",
      "type": "java.util.List<java.lang.String>",
      "description": "Allowed values for @Masking(strategy).",
      "defaultValue": ["FULL","PARTIAL","HASH","TOKENIZE"]
    },
    {
      "name": "dbvcs.allowed-values.retention-types",
      "type": "java.util.List<java.lang.String>",
      "description": "Allowed values for @DataRetention(type).",
      "defaultValue": ["ONE_YEAR","THREE_YEARS","FIVE_YEARS","SEVEN_YEARS","TEN_YEARS","INDEFINITE","UNTIL_CONSENT_WITHDRAWN","CUSTOM"]
    },
    {
      "name": "dbvcs.allowed-values.lifecycle-stages",
      "type": "java.util.List<java.lang.String>",
      "description": "Allowed values for @Lifecycle(value).",
      "defaultValue": ["ACTIVE","DEPRECATED","ARCHIVED","LEGACY"]
    },
    {
      "name": "dbvcs.allowed-values.frequencies",
      "type": "java.util.List<java.lang.String>",
      "description": "Allowed values for @RefreshFrequency(value).",
      "defaultValue": ["REALTIME","HOURLY","DAILY","WEEKLY","MONTHLY"]
    },
    {
      "name": "dbvcs.allowed-values.update-types",
      "type": "java.util.List<java.lang.String>",
      "description": "Allowed values for @UpdateStrategy(value).",
      "defaultValue": ["APPEND_ONLY","UPSERT","FULL_REFRESH","EVENT_DRIVEN"]
    },
    {
      "name": "dbvcs.allowed-values.quality-levels",
      "type": "java.util.List<java.lang.String>",
      "description": "Allowed values for @DataQualityLevel(level).",
      "defaultValue": ["LOW","MEDIUM","HIGH","VERIFIED"]
    },
    {
      "name": "dbvcs.validation.enabled",
      "type": "java.lang.Boolean",
      "description": "Whether to enable runtime annotation validation on @Entity classes at startup. When a ValidationRuleRegistry bean is present, validation is always active regardless of this flag.",
      "defaultValue": false
    },
    {
      "name": "dbvcs.validation.fail-on-violation",
      "type": "java.lang.Boolean",
      "description": "Whether to abort application startup when annotation violations are found. Set to false to log warnings only.",
      "defaultValue": false
    },
    {
      "name": "dbvcs.validation.required-annotations",
      "type": "java.util.List<java.lang.String>",
      "description": "Simple class names of annotations that must be present on every scanned @Entity (e.g. Domain, BusinessModule, DataClassification). Applies globally unless overridden by a package rule.",
      "defaultValue": []
    },
    {
      "name": "dbvcs.validation.rules",
      "type": "java.util.List<com.dbvcs.autoconfigure.DbvcsProperties$ValidationRules$PackageRule>",
      "description": "List of package-specific validation rules. Each rule defines a package pattern and required annotation names. Rules are checked in declaration order; the first match wins and is merged with global required-annotations."
    },
    {
      "name": "dbvcs.validation.rules[n].package-pattern",
      "type": "java.lang.String",
      "description": "Package pattern for this rule. Supports wildcards: 'com.example.*' (single level) or 'com.example.**' (recursive). Exact class names are also accepted."
    },
    {
      "name": "dbvcs.validation.rules[n].required-annotations",
      "type": "java.util.List<java.lang.String>",
      "description": "Simple class names of annotations required for entities matching this package pattern. Merged with the global required-annotations list.",
      "defaultValue": []
    }
  ]
}
